{
  "santos": [
    { "id":"francisco-assis", "nome":"São Francisco de Assis", "festa":"4 de outubro", "padroeiro":"Ecologia, animais", "resumo":"Nascido em Assis, na Itália, por volta de 1181, renunciou à riqueza da família para viver em pobreza radical e fundou a Ordem dos Frades Menores. É lembrado por seu amor à criação e por receber os estigmas de Cristo." },
    { "id":"antonio-padua", "nome":"Santo Antônio de Pádua", "festa":"13 de junho", "padroeiro":"Objetos perdidos, casamentos", "resumo":"Frade franciscano português do século XIII, famoso pregador e conhecido por sua devoção ao Menino Jesus. É invocado tradicionalmente para achar coisas perdidas." },
    { "id":"teresa-avila", "nome":"Santa Teresa de Ávila", "festa":"15 de outubro", "padroeiro":"Doutora da Igreja, contemplativos", "resumo":"Religiosa carmelita espanhola do século XVI, reformadora da sua ordem e grande mestra da oração e da vida interior. É uma das poucas mulheres declaradas Doutoras da Igreja." },
    { "id":"joao-paulo-ii", "nome":"São João Paulo II", "festa":"22 de outubro", "padroeiro":"Jovens, famílias", "resumo":"Karol Wojtyła, papa polonês de 1978 a 2005, um dos pontificados mais longos da história. Conhecido por suas viagens pelo mundo e pelo papel na queda do comunismo no Leste Europeu." },
    { "id":"padre-pio", "nome":"São Padre Pio de Pietrelcina", "festa":"23 de setembro", "padroeiro":"Confessores, aflitos", "resumo":"Frade capuchinho italiano do século XX, conhecido pelos estigmas que carregou por décadas e por passar horas diárias no confessionário atendendo fiéis." },
    { "id":"jose", "nome":"São José", "festa":"19 de março", "padroeiro":"Trabalhadores, Igreja Universal", "resumo":"Esposo de Maria e pai adotivo de Jesus, era carpinteiro em Nazaré. É modelo de fé silenciosa e cuidado com a família, e padroeiro da Igreja Universal." },
    { "id":"nossa-senhora-aparecida", "nome":"Nossa Senhora Aparecida", "festa":"12 de outubro", "padroeiro":"Padroeira do Brasil", "resumo":"Imagem de Nossa Senhora da Conceição encontrada por pescadores no Rio Paraíba do Sul em 1717. É a padroeira do Brasil, venerada no Santuário Nacional em Aparecida (SP)." },
    { "id":"terezinha", "nome":"Santa Teresinha do Menino Jesus", "festa":"1 de outubro", "padroeiro":"Missões, floristas", "resumo":"Carmelita francesa falecida aos 24 anos em 1897, autora de 'História de uma Alma'. Ensinou o 'caminhozinho' de confiança e amor nas pequenas coisas do dia a dia." },
    { "id":"agostinho", "nome":"Santo Agostinho", "festa":"28 de agosto", "padroeiro":"Doutor da Igreja, teólogos", "resumo":"Bispo de Hipona no norte da África, viveu entre os séculos IV e V. Depois de uma juventude afastada da fé, converteu-se e tornou-se um dos maiores teólogos da história da Igreja." },
    { "id":"tomas-aquino", "nome":"Santo Tomás de Aquino", "festa":"28 de janeiro", "padroeiro":"Doutor Angélico, estudantes", "resumo":"Frade dominicano do século XIII, autor da Suma Teológica. É considerado o maior expoente da filosofia escolástica e um dos principais teólogos da Igreja." },
    { "id":"maximiliano-kolbe", "nome":"São Maximiliano Kolbe", "festa":"14 de agosto", "padroeiro":"Prisioneiros, jornalistas", "resumo":"Frade franciscano polonês que se ofereceu para morrer no lugar de um prisioneiro no campo de concentração de Auschwitz, em 1941." },
    { "id":"rita-cascia", "nome":"Santa Rita de Cássia", "festa":"22 de maio", "padroeiro":"Causas impossíveis, casos difíceis", "resumo":"Religiosa agostiniana italiana do século XV, viúva antes de ingressar na vida religiosa. É conhecida como a santa das causas impossíveis." },
    { "id":"francisco-xavier", "nome":"São Francisco Xavier", "festa":"3 de dezembro", "padroeiro":"Missões", "resumo":"Um dos primeiros companheiros de Santo Inácio de Loyola, jesuíta espanhol que levou o Evangelho à Índia, ao Japão e a outras partes da Ásia no século XVI." },
    { "id":"catarina-siena", "nome":"Santa Catarina de Sena", "festa":"29 de abril", "padroeiro":"Doutora da Igreja, Itália e Europa", "resumo":"Leiga dominicana italiana do século XIV, teve papel decisivo em convencer o Papa a retornar de Avignon a Roma. É Doutora da Igreja e copadroeira da Europa." },
    { "id":"charbel", "nome":"São Charbel Makhlouf", "festa":"24 de julho", "padroeiro":"Doenças, curas", "resumo":"Monge eremita maronita do Líbano, falecido em 1898, conhecido por sua vida de intensa penitência e pelas muitas curas atribuídas à sua intercessão." }
  ]
}
